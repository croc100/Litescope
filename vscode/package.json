{
  "name": "litescope",
  "displayName": "Litescope",
  "description": "SQLite explorer and visual diff — browse tables, compare databases",
  "version": "0.1.0",
  "publisher": "croc100",
  "license": "Elastic-2.0",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "keywords": ["sqlite", "database", "diff", "explorer", "db"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "litescope",
          "title": "Litescope",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "litescope": [
        {
          "id": "litescope.databases",
          "name": "Databases",
          "icon": "media/icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "litescope.openDatabase",
        "title": "Open Database",
        "icon": "$(add)",
        "category": "Litescope"
      },
      {
        "command": "litescope.diffDatabases",
        "title": "Compare Databases",
        "icon": "$(diff)",
        "category": "Litescope"
      },
      {
        "command": "litescope.closeDatabase",
        "title": "Close Database",
        "icon": "$(close)",
        "category": "Litescope"
      },
      {
        "command": "litescope.refreshDatabase",
        "title": "Refresh",
        "icon": "$(refresh)",
        "category": "Litescope"
      }
    ],
    "customEditors": [
      {
        "viewType": "litescope.dbViewer",
        "displayName": "Litescope DB Viewer",
        "selector": [
          { "filenamePattern": "*.db" },
          { "filenamePattern": "*.sqlite" },
          { "filenamePattern": "*.sqlite3" }
        ],
        "priority": "default"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "litescope.openDatabase",
          "when": "view == litescope.databases",
          "group": "navigation@1"
        },
        {
          "command": "litescope.diffDatabases",
          "when": "view == litescope.databases",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "litescope.refreshDatabase",
          "when": "viewItem == database",
          "group": "inline@1"
        },
        {
          "command": "litescope.closeDatabase",
          "when": "viewItem == database",
          "group": "inline@2"
        }
      ],
      "explorer/context": [
        {
          "command": "litescope.openDatabase",
          "when": "resourceExtname =~ /\\.(db|sqlite|sqlite3)$/",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "npm run build:ext && npm run build:webview",
    "build:ext": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify",
    "build:webview": "cd webview-ui && npm run build",
    "watch:ext": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap --watch",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.24.0"
  }
}
